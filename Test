case ATMEL_IOCTL_SET_MODE:
                        /* 1. Disable RX/TX */
                        atmel_uart_writel(port, ATMEL_US_CR, ATMEL_US_RXDIS | ATMEL_US_TXDIS);


                        atmel_uart_writel(port, ATMEL_US_CR, ATMEL_US_RSTTX | ATMEL_US_RSTRX);

                        /* 2. USART Mode Register */
                        mr = atmel_uart_readl(port, ATMEL_US_MR);
                        mr &= ~(ATMEL_US_USMODE | ATMEL_US_PAR | ATMEL_US_CHRL | ATMEL_US_NBSTOP | ATMEL_US_CHMODE);

                        mr |= ATMEL_US_USMODE_LIN_MASTER | ATMEL_US_PAR_NONE | ATMEL_US_CHRL_8 | ATMEL_US_NBSTOP_1 | ATMEL_US_CHMODE_NORMAL;

                        atmel_uart_writel(port, ATMEL_US_MR, mr);

                        /* 3. LIN Mode Register */
                        linmr = 0x710;
                        atmel_uart_writel(port, ATMEL_US_LINMR, linmr);

                        /* 4. Re-enable RX/TX */
                        atmel_uart_writel(port, ATMEL_US_CR, ATMEL_US_RXEN | ATMEL_US_TXEN);

                        break;
case ATMEL_IOCTL_SET_LIN_ID:

                        if(copy_from_user (&linid , (void __user*) arg ,sizeof(linid)) )
                                 return -EFAULT;

                        atmel_uart_writel(port, ATMEL_US_CR, ATMEL_US_RSTSTA);

                        while(!(atmel_uart_readl(port, ATMEL_US_CSR) & ATMEL_US_TXRDY));
                        if(linid == 0x3D)
                        {
                                linmr = 0x711;
                                for (iter= 0; iter < 8; iter++)
                                {
                                        rec_data[iter] = 0x00;
                                }

                                iter = 0;

                                atmel_uart_writel(port, ATMEL_US_LINMR, linmr);
                                while(atmel_uart_readl(port, ATMEL_US_LINMR) != linmr);

                                atmel_uart_writel(port, ATMEL_US_LINIR,linid);

                                while(!(atmel_uart_readl(port, ATMEL_US_CSR) & ATMEL_US_LINID));
                                while (iter < 8)
                                {
                                        while (!(atmel_uart_readl(port, ATMEL_US_CSR) & ATMEL_US_RXRDY));

                                        rec_data[iter] = atmel_uart_readl(port, ATMEL_US_RHR) & 0xFF;
                                        iter++;
                                }
                        }
                else if(linid == 0x3C)
                        {
                                linmr = 0x710;
                                atmel_uart_writel(port, ATMEL_US_LINMR, linmr);

                                while(atmel_uart_readl(port, ATMEL_US_LINMR) != linmr);

                                atmel_uart_writel(port, ATMEL_US_LINIR,linid);

                //              while(!(atmel_uart_readl(port, ATMEL_US_CSR) & ATMEL_US_LINID));
                                for(iter = 0 ; iter < 8; iter++)
                                {
                                      while(!(atmel_uart_readl(port, ATMEL_US_CSR) & ATMEL_US_TXRDY));
                                      atmel_uart_writel(port, ATMEL_US_THR, send_data[iter]);

                                }
                        }
                        else
                        {
                                /* Do nothing*/
                        }
                        while(!(atmel_uart_readl(port, ATMEL_US_CSR) & ATMEL_US_LINTC));

                        test_val = atmel_uart_readl(port, ATMEL_US_CSR);

                        if(test_val &(ATMEL_US_LINBE | ATMEL_US_LINISFE | ATMEL_US_LINIPE | ATMEL_US_LINCE | ATMEL_US_LINSNRE | ATMEL_US_LINSTE |  ATMEL_US_LINHTE ))
                                printk(KERN_INFO "LIN CSR Error %x\t",test_val);

                        atmel_uart_writel(port, ATMEL_US_CR, ATMEL_US_RSTSTA);
                        if(linid == 0x3D)
                        {
                                for (iter= 0; iter < 8; iter++)
                                {
                                        printk(KERN_INFO "Response Data: %x\t",rec_data[iter]);
                                }
                        }

                        break;
